<Window x:Class="ImageTextComparer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Image Text Comparer" Height="780" Width="1200"
        Background="{DynamicResource WindowBg}" WindowStartupLocation="CenterScreen"
        MinHeight="700" MinWidth="1000">
    
    <Window.Resources>
        <!-- Theme Color Brushes (Default Dark Theme) -->
        <SolidColorBrush x:Key="WindowBg" Color="#0F0F12"/>
        <SolidColorBrush x:Key="PanelBg" Color="#18181C"/>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#27272A"/>
        <SolidColorBrush x:Key="TextFg" Color="#F4F4F5"/>
        <SolidColorBrush x:Key="TextLabelFg" Color="#A1A1AA"/>
        <SolidColorBrush x:Key="TextBoxBg" Color="#121214"/>
        <SolidColorBrush x:Key="TextBoxBorder" Color="#3F3F46"/>
        <SolidColorBrush x:Key="ActionBtnBg" Color="#27272A"/>
        <SolidColorBrush x:Key="ActionBtnFg" Color="#F4F4F5"/>
        <SolidColorBrush x:Key="ImageAreaBg" Color="#0A0A0C"/>

        <!-- Modern ScrollViewer style -->
        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                   CanContentScroll="{TemplateBinding CanContentScroll}"
                                                   ContentTemplate="{TemplateBinding ContentTemplate}"
                                                   Content="{TemplateBinding Content}"
                                                   Margin="{TemplateBinding Padding}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      HorizontalAlignment="Right"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Width="8"
                                      AutomationProperties.AutomationId="VerticalScrollBar"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom modern Scrollbar track and thumb -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{DynamicResource ImageAreaBg}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Visibility="Collapsed"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}" Visibility="Collapsed"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="{DynamicResource TextBoxBorder}" BorderBrush="Transparent"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded corner styles -->
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Modern Label style -->
        <Style x:Key="ModernLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextLabelFg}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Config Textbox style -->
        <Style x:Key="ConfigTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource TextBoxBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextBoxBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionBrush" Value="#6366F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#52525B"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource TextBoxBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Action Button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ActionBtnBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource ActionBtnFg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PanelBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLabelFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Compare Gradient Button -->
        <Style x:Key="CompareButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#6366F1" Offset="0"/>
                        <GradientStop Color="#8B5CF6" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource TextBoxBorder}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextLabelFg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <!-- Settings Sidebar -->
            <ColumnDefinition Width="280"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR - API CONFIGURATION -->
        <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,16,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="CẤU HÌNH AI" Foreground="{DynamicResource TextFg}" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="API Endpoint URL" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="TxtEndpoint" Style="{StaticResource ConfigTextBox}" 
                             Text="http://localhost:11434/v1/chat/completions" Margin="0,0,0,14"/>

                    <TextBlock Text="API Key (nếu có)" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="TxtApiKey" Style="{StaticResource ConfigTextBox}" 
                             Text="" Margin="0,0,0,14" />

                    <TextBlock Text="Model Name" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="TxtModelName" Style="{StaticResource ConfigTextBox}" 
                             Text="qwen2.5-vl" Margin="0,0,0,14"/>

                    <CheckBox x:Name="ChkBypassSsl" Content="Bỏ qua xác thực SSL (tự ký)" 
                              Foreground="{DynamicResource TextLabelFg}" FontSize="12" Margin="0,0,0,14" VerticalAlignment="Center"/>

                    <TextBlock Text="AI Prompts" Style="{StaticResource ModernLabel}"/>
                    <TextBox x:Name="TxtPrompt" Style="{StaticResource ConfigTextBox}" 
                             AcceptsReturn="True" TextWrapping="Wrap" Height="100" VerticalScrollBarVisibility="Auto"
                             Text="Perform strict, literal character-by-character OCR on the image. Do NOT auto-correct spelling or change characters based on context. Specifically, in Japanese, carefully distinguish between Dakuten (゛, e.g., バ, ズ) and Handakuten (゜, e.g., パ, プ). Output exactly what you see.&#x0a;&#x0a;Hãy trích xuất chính xác từng ký tự dưới dạng OCR thuần túy. Phân biệt rõ giữa dakuten (゛ - ví dụ: バ) và handakuten (゜ - ví dụ: パ). Không tự sửa chính tả theo ngữ cảnh.&#x0a;&#x0a;画像からテキストを1文字ずつ正確に抽出（OCR）してください。文脈によるスペル修正や推測は一切行わないでください。特に濁点（゛、例：バ）と半濁点（゜、例：パ）を厳密に区別してください。" 
                             Margin="0,0,0,20"/>

                    <Button Content="Lưu cấu hình" Style="{StaticResource ActionButton}" Click="BtnSaveConfig_Click" Margin="0,0,0,10"/>
                    <Button Content="Đặt về mặc định" Style="{StaticResource ActionButton}" Click="BtnResetConfig_Click" Margin="0,0,0,10"/>
                    <Button Content="Mở thư mục chẩn đoán" Style="{StaticResource ActionButton}" Click="BtnOpenDebugFolder_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- MAIN WORKSPACE -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Title / Header -->
                <RowDefinition Height="Auto"/>
                <!-- Image Loading & Crop Canvas -->
                <RowDefinition Height="*"/>
                <!-- Extract Action Button -->
                <RowDefinition Height="Auto"/>
                <!-- Result & Text Comparison Side-by-Side -->
                <RowDefinition Height="240"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock FontSize="20" FontWeight="ExtraBold" VerticalAlignment="Center">
                        <Run Text="IMAGE TEXT " Foreground="{DynamicResource TextFg}"/>
                        <Run Text="COMPARER" Foreground="#6366F1"/>
                    </TextBlock>
                    <TextBlock Text="— So sánh nội dung chữ trong ảnh" 
                               Foreground="{DynamicResource TextLabelFg}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Theme Toggle Button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnToggleTheme" Content="☀️ Sáng" Style="{StaticResource ActionButton}" Padding="10,5" Click="BtnToggleTheme_Click"/>
                </StackPanel>
            </Grid>

            <!-- IMAGE LAYOUT -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- IMAGE 1 PANEL -->
                <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Ảnh 1 (Bản gốc)" Foreground="{DynamicResource TextFg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnClearCrop1" Content="Hủy chọn vùng" Style="{StaticResource ActionButton}" FontSize="11" Padding="8,4" Click="BtnClearCrop1_Click" Margin="0,0,6,0" Visibility="Collapsed"/>
                                <Button Content="Chọn ảnh..." Style="{StaticResource ActionButton}" FontSize="11" Padding="8,4" Click="BtnLoadImage1_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Image Container with Crop Canvas overlay -->
                        <Border Grid.Row="1" Background="{DynamicResource ImageAreaBg}" CornerRadius="6" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <!-- Placeholder message -->
                                <StackPanel x:Name="Placeholder1" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="Chưa chọn hình ảnh" Foreground="{DynamicResource TextLabelFg}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="Dùng chuột quét vùng để trích xuất tập trung" Foreground="{DynamicResource TextLabelFg}" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Center-aligned Viewbox that scales the pixel-bound grid natively -->
                                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid x:Name="GridImage1">
                                        <Image x:Name="Img1" Stretch="None"/>
                                        
                                        <Canvas x:Name="Canvas1" Background="Transparent" 
                                                Cursor="Cross"
                                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                                MouseMove="Canvas_MouseMove"
                                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
                                            <Rectangle x:Name="RectSelection1" Stroke="#6366F1" StrokeThickness="1.5" StrokeDashArray="4 3" Fill="#1E6366F1" Visibility="Collapsed"/>
                                        </Canvas>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtInfo1" Grid.Row="2" Margin="0,8,0,0" Text="Kích thước: -" Foreground="{DynamicResource TextLabelFg}" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- IMAGE 2 PANEL -->
                <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Ảnh 2 (Bản đối chiếu)" Foreground="{DynamicResource TextFg}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnClearCrop2" Content="Hủy chọn vùng" Style="{StaticResource ActionButton}" FontSize="11" Padding="8,4" Click="BtnClearCrop2_Click" Margin="0,0,6,0" Visibility="Collapsed"/>
                                <Button Content="Chọn ảnh..." Style="{StaticResource ActionButton}" FontSize="11" Padding="8,4" Click="BtnLoadImage2_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Image Container with Crop Canvas overlay -->
                        <Border Grid.Row="1" Background="{DynamicResource ImageAreaBg}" CornerRadius="6" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <!-- Placeholder message -->
                                <StackPanel x:Name="Placeholder2" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock Text="Chưa chọn hình ảnh" Foreground="{DynamicResource TextLabelFg}" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <TextBlock Text="Dùng chuột quét vùng để trích xuất tập trung" Foreground="{DynamicResource TextLabelFg}" FontSize="11" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Center-aligned Viewbox that scales the pixel-bound grid natively -->
                                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid x:Name="GridImage2">
                                        <Image x:Name="Img2" Stretch="None"/>
                                        
                                        <Canvas x:Name="Canvas2" Background="Transparent" 
                                                Cursor="Cross"
                                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                                                MouseMove="Canvas_MouseMove"
                                                MouseLeftButtonUp="Canvas_MouseLeftButtonUp">
                                            <Rectangle x:Name="RectSelection2" Stroke="#8B5CF6" StrokeThickness="1.5" StrokeDashArray="4 3" Fill="#1E8B5CF6" Visibility="Collapsed"/>
                                        </Canvas>
                                    </Grid>
                                </Viewbox>
                            </Grid>
                        </Border>

                        <TextBlock x:Name="TxtInfo2" Grid.Row="2" Margin="0,8,0,0" Text="Kích thước: -" Foreground="{DynamicResource TextLabelFg}" FontSize="11"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- TRIGGER BUTTON PANEL -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" x:Name="BtnCompare" Content="TRÍCH XUẤT &amp; SO SÁNH" Style="{StaticResource CompareButton}" Click="BtnCompare_Click"/>
                
                <!-- Loading indicator overlay -->
                <TextBlock x:Name="TxtStatus" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20,0,0,0" Foreground="{DynamicResource TextLabelFg}" FontSize="12"/>
            </Grid>

            <!-- TEXT RESULTS & COMPARISON SIDE-BY-SIDE -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT TEXT BOX (ORIGINAL RESULTS) -->
                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="KẾT QUẢ VĂN BẢN 1 (Đã xóa / Khác biệt)" Foreground="#EF4444" FontSize="11" FontWeight="Bold" Margin="8,4,8,8"/>
                        <RichTextBox Grid.Row="1" x:Name="RtfText1" IsReadOnly="True" Background="Transparent" BorderThickness="0" 
                                     VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>

                <!-- RIGHT TEXT BOX (MODIFIED RESULTS) -->
                <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="KẾT QUẢ VĂN BẢN 2 (Đã thêm / Thay thế)" Foreground="#10B981" FontSize="11" FontWeight="Bold" Margin="8,4,8,8"/>
                        <RichTextBox Grid.Row="1" x:Name="RtfText2" IsReadOnly="True" Background="Transparent" BorderThickness="0" 
                                     VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
